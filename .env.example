# Generate this key in the Sub2API administration console.
SUB2API_ADMIN_API_KEY=replace-with-sub2api-admin-key
SUB2API_BASE_URL=http://sub2api:8080
# Docker Compose external network containing the Sub2API service.
SUB2API_DOCKER_NETWORK=sub2api_sub2api-network
LISTEN_ADDRESS=:8323
BASE_PATH=/scheduler/
DATABASE_PATH=/data/scheduler.db
POLL_INTERVAL=50s
REQUEST_TIMEOUT=12s
SESSION_IDLE_TIMEOUT=30m
COOKIE_SECURE=true
DRY_RUN=true
FAILURE_THRESHOLD=3
RECOVERY_THRESHOLD=3
MANUAL_HOLD_MINUTES=10
FLAP_WINDOW_MINUTES=60
FLAP_PAUSE_THRESHOLD=3
FLAP_RECOVERY_THRESHOLD=10
BALANCE_POLL_INTERVAL=10m
TELEMETRY_POLL_INTERVAL=2m
# Generate each key independently with: openssl rand -base64 32
UPSTREAM_CREDENTIAL_KEY=replace-with-a-32-byte-base64-key
AGENT_CREDENTIAL_KEY=replace-with-a-different-32-byte-base64-key
ALLOW_INSECURE_UPSTREAMS=false
